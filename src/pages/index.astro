---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Lazuardi XAUUSD - Gold & Celestial Intelligence Portal">
	<Header />
	
	<main class="landing-main">
		<section class="hero-section">
			<div class="hero-content">
				<h1 class="hero-title">LAZUARDI</h1>
				<p class="hero-subtitle">GOLD INTELLIGENCE GATEWAY</p>
				<p class="hero-description">
					A dual-engine predictive environment designed for XAUUSD analysis. 
					Seamlessly bridge the gap between classical financial quantitative technical metrics and celestial astronomical cycle correlations.
				</p>
			</div>
		</section>

		<section class="portal-grid">
			<!-- Option 1: Standard Dashboard -->
			<a href="/dashboard-xauusd" class="portal-card gold-portal glass-panel-gold">
				<div class="card-glow"></div>
				<div class="card-content">
					<div class="card-header">
						<div class="card-icon gold-icon">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23"></line>
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
							</svg>
						</div>
						<div class="badge gold-badge">QUANTITATIVE</div>
					</div>
					
					<h2 class="card-title">Dashboard XAUUSD</h2>
					<p class="card-subtitle">Technical & Market Indicators</p>
					<p class="card-desc">
						Analyze gold market dynamics using real-time price feeds, volume indicators, moving averages, relative strength index (RSI), and pivot point tables. Built for tactical day-traders and asset managers.
					</p>

					<div class="sparkline-container">
						<svg class="sparkline" viewBox="0 0 100 30">
							<path d="M0,25 Q15,10 30,20 T60,5 T90,15 L100,10" fill="none" stroke="url(#sparkline-gold)" stroke-width="2" stroke-linecap="round"></path>
							<defs>
								<linearGradient id="sparkline-gold" x1="0" y1="0" x2="1" y2="0">
									<stop offset="0%" stop-color="#1d4ed8"></stop>
									<stop offset="100%" stop-color="#3b82f6"></stop>
								</linearGradient>
							</defs>
						</svg>
						<span class="sparkline-label">LIVE DATA FEED ACTIVE</span>
					</div>

					<ul class="card-features">
						<li>
							<svg class="feat-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
							Interactive Price Charting
						</li>
						<li>
							<svg class="feat-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
							Technical Indicators (RSI, MACD)
						</li>
						<li>
							<svg class="feat-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
							Support, Resistance & Pivot Levels
						</li>
					</ul>

					<span class="card-btn btn-gold">Enter Technical Terminal &rarr;</span>
				</div>
			</a>

			<!-- Option 2: Astrology Dashboard -->
			<a href="/dashboard-astrologi-xauusd" class="portal-card astro-portal glass-panel-astro">
				<div class="card-glow"></div>
				<div class="card-content">
					<div class="card-header">
						<div class="card-icon astro-icon">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 3a6.36 6.36 0 0 1 9 9 9.75 9.75 0 0 0-9-9Z"></path>
								<path d="M11.3 12.7a5 5 0 1 1-7.1-7.1 9.75 9.75 0 0 0 7.1 7.1Z"></path>
								<path d="M12 22a9.75 9.75 0 0 0 9-9 9.75 9.75 0 0 0-9 9Z"></path>
							</svg>
						</div>
						<div class="badge astro-badge">COSMIC</div>
					</div>
					
					<h2 class="card-title">Dashboard Astrologi</h2>
					<p class="card-subtitle">Celestial Mechanics Correlation</p>
					<p class="card-desc">
						Explore gold volatility mapped against planetary alignments, Mercury retrogrades, lunar synodic phases, and solar transits. Examine historical patterns matching financial astrology to major market reversals.
					</p>

					<div class="sparkline-container">
						<div class="constellation-spark">
							<span class="star-node shine"></span>
							<span class="star-line"></span>
							<span class="star-node"></span>
							<span class="star-line"></span>
							<span class="star-node shine2"></span>
						</div>
						<span class="sparkline-label">CELESTIAL CALCULATIONS SYNCED</span>
					</div>

					<ul class="card-features">
						<li>
							<svg class="feat-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
							Lunar Phase Volatility Correlation
						</li>
						<li>
							<svg class="feat-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
							Mercury Retrograde Market Impact
						</li>
						<li>
							<svg class="feat-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
							Astrological Reversal Signal Alerts
						</li>
					</ul>

					<span class="card-btn btn-astro">Enter Cosmic Terminal &rarr;</span>
				</div>
			</a>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.landing-main {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 3rem 2rem 5rem;
		max-width: 1400px;
		margin: 0 auto;
		width: 100%;
		z-index: 10;
	}

	.hero-section {
		text-align: center;
		margin-bottom: 4rem;
		max-width: 800px;
		position: relative;
	}

	/* Ambient backglow */
	.hero-section::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 250px;
		height: 250px;
		background: radial-gradient(circle, rgba(212,175,55,0.08) 0%, rgba(139,92,246,0.05) 50%, rgba(0,0,0,0) 100%);
		z-index: -1;
		filter: blur(40px);
		pointer-events: none;
	}

	.hero-title {
		font-family: var(--font-display);
		font-size: 3.5rem;
		font-weight: 900;
		letter-spacing: 0.25em;
		background: linear-gradient(135deg, #fff 40%, var(--accent-gold) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		margin-bottom: 0.5rem;
		text-shadow: 0 0 40px rgba(212, 175, 55, 0.2);
	}

	.hero-subtitle {
		font-family: var(--font-sans);
		font-size: 0.95rem;
		font-weight: 800;
		letter-spacing: 0.4em;
		color: var(--text-muted);
		margin-bottom: 2rem;
		text-transform: uppercase;
	}

	.hero-description {
		font-size: 1.125rem;
		color: var(--text-secondary);
		line-height: 1.7;
		font-weight: 400;
	}

	.portal-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2.5rem;
		width: 100%;
		perspective: 1000px;
	}

	/* Card Styles */
	.portal-card {
		position: relative;
		text-decoration: none;
		color: inherit;
		overflow: hidden;
		transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
		cursor: pointer;
		display: flex;
		flex-direction: column;
	}

	.portal-card::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: 16px;
		padding: 1px;
		background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%);
		-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		pointer-events: none;
	}

	.gold-portal:hover {
		transform: translateY(-8px) scale(1.01);
		box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 30px rgba(212, 175, 55, 0.25);
		border-color: rgba(212, 175, 55, 0.4);
	}

	.astro-portal:hover {
		transform: translateY(-8px) scale(1.01);
		box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 30px rgba(139, 92, 246, 0.25);
		border-color: rgba(139, 92, 246, 0.4);
	}

	.card-content {
		padding: 3rem;
		display: flex;
		flex-direction: column;
		height: 100%;
		position: relative;
		z-index: 2;
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
	}

	.card-icon {
		width: 48px;
		height: 48px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.05);
		color: var(--text-secondary);
		transition: all 0.3s ease;
	}

	.portal-card:hover .card-icon {
		transform: scale(1.1) rotate(5deg);
	}

	.gold-portal:hover .gold-icon {
		color: var(--accent-gold);
		background: rgba(212, 175, 55, 0.1);
		border-color: rgba(212, 175, 55, 0.2);
	}

	.astro-portal:hover .astro-icon {
		color: var(--accent-astro);
		background: rgba(139, 92, 246, 0.1);
		border-color: rgba(139, 92, 246, 0.2);
	}

	.badge {
		font-size: 0.65rem;
		font-weight: 800;
		letter-spacing: 0.15em;
		padding: 0.4rem 0.8rem;
		border-radius: 9999px;
	}

	.gold-badge {
		background: rgba(212, 175, 55, 0.1);
		color: var(--accent-gold);
		border: 1px solid rgba(212, 175, 55, 0.2);
	}

	.astro-badge {
		background: rgba(139, 92, 246, 0.1);
		color: var(--accent-astro);
		border: 1px solid rgba(139, 92, 246, 0.2);
	}

	.card-title {
		font-family: var(--font-display);
		font-size: 2rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 0.35rem;
		letter-spacing: 0.05em;
	}

	.card-subtitle {
		font-size: 0.875rem;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.card-desc {
		font-size: 0.95rem;
		color: var(--text-secondary);
		line-height: 1.6;
		margin-bottom: 2rem;
		flex-grow: 1;
	}

	/* Sparkline decoration */
	.sparkline-container {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		background: rgba(0, 0, 0, 0.2);
		padding: 1rem;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.03);
		margin-bottom: 2rem;
	}

	.sparkline {
		width: 100%;
		height: 35px;
	}

	/* Constellation animation decoration */
	.constellation-spark {
		height: 35px;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
	}

	.star-node {
		width: 6px;
		height: 6px;
		background: #8b5cf6;
		border-radius: 50%;
		box-shadow: 0 0 10px #8b5cf6;
	}

	.star-node.shine {
		animation: blink 2s infinite ease-in-out;
	}

	.star-node.shine2 {
		animation: blink 2s infinite ease-in-out;
		animation-delay: 1s;
	}

	.star-line {
		width: 40px;
		height: 1px;
		background: linear-gradient(90deg, #8b5cf6, rgba(139, 92, 246, 0.1));
	}

	@keyframes blink {
		0%, 100% { opacity: 0.3; transform: scale(0.8); }
		50% { opacity: 1; transform: scale(1.3); box-shadow: 0 0 15px #8b5cf6, 0 0 30px #8b5cf6; }
	}

	.sparkline-label {
		font-family: monospace;
		font-size: 0.65rem;
		color: var(--text-muted);
		letter-spacing: 0.05em;
		text-align: center;
	}

	.card-features {
		list-style: none;
		margin-bottom: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.card-features li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.9rem;
		color: var(--text-secondary);
	}

	.feat-check {
		width: 16px;
		height: 16px;
		color: #10b981;
	}

	.card-btn {
		width: 100%;
		text-align: center;
	}

	@media (max-width: 1024px) {
		.portal-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		
		.card-content {
			padding: 2rem;
		}
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 2.5rem;
		}
		
		.landing-main {
			padding: 2rem 1rem 3rem;
		}
	}
</style>
