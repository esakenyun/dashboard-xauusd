function wrColorIhsg(wr){
  const t = Math.max(0, Math.min(1, (wr-30)/35));
  const r = Math.round(181 + (127-181)*t);
  const g = Math.round(83 + (168-83)*t);
  const b = Math.round(60 + (138-60)*t);
  return 'rgb('+r+','+g+','+b+')';
}

function buildHeatmapIhsg(){
  const table = document.getElementById('heatmapTable');
  if(!table) return;
  let html = '<thead><tr><th style="text-align:left">Planet</th>' + ZODIAC_IHSG.map(z=>'<th>'+z.slice(0,3)+'</th>').join('') + '</tr></thead><tbody>';
  Object.keys(PLANET_LABEL_IHSG).forEach(p=>{
    html += '<tr><td style="font-family:var(--mono);color:var(--gold)">'+PLANET_LABEL_IHSG[p]+'</td>';
