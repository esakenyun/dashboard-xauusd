  let html = '<thead><tr><th style="text-align:left">Planet</th>' + ZODIAC_PE.map(z=>'<th>'+z.slice(0,3)+'</th>').join('') + '</tr></thead><tbody>';
  PLANETS_PE.forEach(p=>{
    html += '<tr><td style="font-family:var(--mono);color:var(--gold)">'+PLANET_LABEL[p]+'</td>';
    ZODIAC_PE.forEach(z=>{
      const cell = WINRATE.signs[p][z];
      if(cell){
        const [wr,n] = cell;
        html += '<td style="background:'+wrColor(wr)+';color:#0b0d16;font-family:var(--mono);font-weight:700;text-align:center;padding:6px 3px" title="n='+n+'">'+wr.toFixed(0)+'</td>';
      } else {
        html += '<td style="text-align:center;color:var(--ink-dim)">-</td>';
      }
    });
    html += '</tr>';
  });
  html += '</tbody>';
  table.innerHTML = html;
}

