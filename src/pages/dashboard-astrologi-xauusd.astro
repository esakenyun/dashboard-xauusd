const PLANET_LABEL = {sun:'Sun',moon:'Moon',venus:'Venus',mars:'Mars',mercury:'Mercury',jupiter:'Jupiter',saturn:'Saturn'};

function wrColor(wr){
  if(wr==null) return 'transparent';
  const t = Math.max(0, Math.min(1, (wr-30)/40));
  const r = Math.round(181 + (127-181)*t);
  const g = Math.round(83 + (168-83)*t);
  const b = Math.round(60 + (138-60)*t);
  return 'rgb('+r+','+g+','+b+')';
}

function buildHeatmap(){
  const table = document.getElementById('heatmapTable');
