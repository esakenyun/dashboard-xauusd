function computeComposite(){
  const div = document.getElementById('compositeResult');
  if(!div) return;
  let sumWN = 0, sumN = 0;
  const parts = [];
  PLANETS_PE.forEach(p=>{
    const sel = document.getElementById('pe_'+p);
    const sign = sel.value;
    const cell = WINRATE.signs[p][sign];
    if(cell){
      const [wr,n] = cell;
      sumWN += wr*n; sumN += n;
      parts.push({label:PLANET_LABEL[p]+' in '+sign, wr, n});
    }
  });
  document.querySelectorAll('#aspectInputs input[type=checkbox]:checked').forEach(cb=>{
    const pair = cb.dataset.pair, asp = cb.dataset.asp;
    const cell = WINRATE.aspects[pair][asp];
    if(cell && cell[0]!=null){
      const [wr,n] = cell;
      sumWN += wr*n; sumN += n;
      parts.push({label:pair+' '+asp, wr, n});
    }
  });
  const composite = sumN>0 ? sumWN/sumN : 50;
  const bull = composite, bear = 100-composite;
  const confN = sumN;
  const confLabel = confN>=1000?'Tinggi':confN>=400?'Sedang':'Rendah';
  div.innerHTML = '<div style="background:var(--bg2);border:1px solid var(--gold);border-radius:10px;padding:16px 18px">'+
    '<div style="display:flex;gap:20px;margin-bottom:10px">'+
    '<div><div style="font-family:var(--mono);font-size:10px;color:var(--ink-dim)">BULL PROBABILITY</div><div style="font-family:var(--display);font-size:30px;color:var(--ok);font-weight:700">'+bull.toFixed(1)+'%</div></div>'+
    '<div><div style="font-family:var(--mono);font-size:10px;color:var(--ink-dim)">BEAR PROBABILITY</div><div style="font-family:var(--display);font-size:30px;color:var(--mars);font-weight:700">'+bear.toFixed(1)+'%</div></div>'+
    '<div><div style="font-family:var(--mono);font-size:10px;color:var(--ink-dim)">CONFIDENCE</div><div style="font-family:var(--display);font-size:30px;color:var(--gold);font-weight:700">'+confLabel+'</div><div style="font-family:var(--mono);font-size:9px;color:var(--ink-dim)">total n='+confN+'</div></div>'+
    '</div>'+
    '<div style="font-family:var(--mono);font-size:10.5px;color:var(--ink-dim)">Komponen: '+parts.map(p=>p.label+' ('+p.wr.toFixed(0)+'%, n='+p.n+')').join(' · ')+'</div>'+
    '</div>';
}

function buildRanking(){
  const tbody = document.getElementById('rankingBody');
  if(!tbody) return;
  const items = [];
  PLANETS_PE.forEach(p=>{
    ZODIAC_PE.forEach(z=>{
      const cell = WINRATE.signs[p][z];
      if(cell && cell[1]>=30){
        items.push({label:PLANET_LABEL[p]+' in '+z, wr:cell[0], n:cell[1]});
      }
    });
  });
  Object.keys(WINRATE.aspects).forEach(pair=>{
    Object.keys(WINRATE.aspects[pair]).forEach(asp=>{
      const cell = WINRATE.aspects[pair][asp];
      if(cell && cell[0]!=null && cell[1]>=30){
        const [a,b] = pair.split('-');
        items.push({label:PLANET_LABEL[a]+'-'+PLANET_LABEL[b]+' '+asp, wr:cell[0], n:cell[1]});
      }
    });
  });
  items.sort((x,y)=>Math.abs(y.wr-50)-Math.abs(x.wr-50));
  tbody.innerHTML = '';
  items.slice(0,20).forEach((it,i)=>{
    const dir = it.wr>50?'Bullish':'Bearish';
    const dirClass = it.wr>50?'up':'down';
    const conf = it.n>=200?'Tinggi':it.n>=80?'Sedang':'Rendah';
    const tr = document.createElement('tr');
    tr.innerHTML = '<td>'+(i+1)+'</td><td>'+it.label+'</td><td class="'+dirClass+'">'+it.wr.toFixed(1)+'%</td><td class="'+dirClass+'">'+dir+'</td><td>'+it.n+'</td><td>'+conf+'</td>';
    tbody.appendChild(tr);
