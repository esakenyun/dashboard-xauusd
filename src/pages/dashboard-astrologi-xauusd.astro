---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Almanak Astro XAUUSD — Panel Harian" description="Catat harga emas tiap hari — posisi planet terisi otomatis (model maju, tanpa retrograde) dan grafik ikut ter-update.">
  <Header />

  <div class="astro-dashboard-page">
    <div class="wrap">

      <header>
        <div class="eyebrow">Almanak Harian · Emas × Langit</div>
        <h1>Panel Astro <span class="accent">XAUUSD</span> 2026</h1>
        <p class="sub">Catat harga emas tiap hari — posisi planet terisi otomatis (model maju, tanpa retrograde) dan grafik ikut ter-update. Data tersimpan di browser Anda.</p>
        <div class="disclaimer">
          <b>Perlu diketahui:</b> astrologi tidak punya dasar ilmiah untuk memprediksi harga. Posisi planet & tanggal di sini adalah astronomi (disederhanakan tanpa retrograde, sesuai permintaan) — <b>bukan sinyal beli/jual</b>. Ini bukan nasihat keuangan.
        </div>
      </header>

      <!-- SIGNATURE: ecliptic sky band -->
      <section class="sky">
        <div class="sky-head">
          <span class="lbl">Peta ekliptika · posisi planet</span>
          <span class="dt" id="skyDate">—</span>
        </div>
        <div class="band" id="band"></div>
      </section>

      <div class="grid">
        <!-- Input -->
        <section class="card">
          <h2>Tambah / perbarui hari</h2>
          <p class="hint">Pilih tanggal, isi harga penutupan emas, simpan. Bisa dipakai tiap hari.</p>
          <label for="dInput">Tanggal</label>
          <input type="date" id="dInput">
          <div class="row2">
            <div>
              <label for="pInput">Harga XAUUSD (USD/oz)</label>
              <input type="number" id="pInput" step="0.01" placeholder="mis. 4066.5" class="num">
            </div>
            <div>
              <label for="sInput">Sumber</label>
              <select id="sInput">
                <option value="aktual">Harga aktual</option>
                <option value="manual">Input manual</option>
              </select>
            </div>
          </div>
          <label>Posisi planet (otomatis, tanpa retrograde)</label>
          <div class="pos-grid" id="posGrid"></div>
          <label for="nInput">Catatan / sentimen (opsional)</label>
          <textarea id="nInput" placeholder="Catatan astrologi atau pasar Anda…"></textarea>
          <div class="toolbar">
            <button class="btn btn-gold" id="saveBtn">Simpan hari ini</button>
            <button class="btn btn-ghost btn-sm" id="todayBtn">Set ke hari ini</button>
          </div>
        </section>

        <!-- Chart -->
        <section class="card chart-card">
          <div class="chart-head">
            <div><h2>Grafik harga emas</h2><p class="hint" style="margin:0">Penutupan XAUUSD sepanjang waktu</p></div>
            <div class="last" id="lastBox">—</div>
          </div>
          <canvas id="chart"></canvas>
        </section>
      </div>

      <!-- Table -->
      <section class="card table-card">
        <div class="chart-head" style="margin-bottom:8px">
          <h2>Tabel data</h2>
          <div class="toolbar" style="margin:0">
            <button class="btn btn-ghost btn-sm" id="csvBtn">Ekspor CSV</button>
            <button class="btn btn-ghost btn-sm" id="resetBtn">Reset ke data awal</button>
          </div>
        </div>
        <table id="tbl">
          <thead><tr>
            <th>Tanggal</th><th>Sun</th><th>Moon</th><th>Venus</th><th>Mars</th>
            <th>Mercury</th><th>Jupiter</th><th>Saturn</th><th>Harga</th><th>Sumber</th><th>Catatan</th><th></th>
          </tr></thead>
          <tbody id="tbody"></tbody>
        </table>
      </section>

      <!-- Research -->
      <details class="research" open>
        <summary>Riset &amp; kesimpulan</summary>
        <div class="body">
          <div class="kpi" id="kpi"></div>
          <h3>Yang diklaim astrologi vs. yang terjadi</h3>
          <p>Narasi lama makin bullish sejak awal April 2026 (“potensi rebound”, “akumulasi menuju 4.800”, “ultra bullish”). Kenyataannya emas justru <b>menurun</b>. Rekor tertinggi ~5.602/oz terjadi 29 Jan 2026 (sebelum jendela analisis), lalu turun hingga menyentuh terendah ~8 bulan di sekitar 3.960 pada akhir Juni, dan baru pulih tipis ke ~4.066 pada 2 Jul 2026 — turun sekitar 11% dalam sebulan. Skenario “menuju 4.800” tidak terkonfirmasi.</p>
          <h3>Penggerak harga yang sebenarnya (Jun–Jul 2026)</h3>
          <ul>
            <li>Ekspektasi kenaikan suku bunga The Fed (~67% peluang di September; ketua baru bernada hawkish) — menaikkan opportunity cost memegang emas.</li>
            <li>Inflasi masih panas (PCE inti ~3,4%, PCE utama ~4,1% yoy).</li>
            <li>Data tenaga kerja kuat &amp; imbal hasil Treasury 10-thn di atas 4,5%.</li>
            <li>Geopolitik AS–Iran / harga minyak.</li>
          </ul>
          <h3>Tentang model “tanpa retrograde”</h3>
          <p>Sesuai permintaan, posisi planet dihitung maju terus memakai gerak rata-rata (mean motion) dari titik acuan 2 Jul 2026 — retrograde diabaikan. Konsekuensinya posisi bersifat perkiraan, terutama untuk planet dalam (Merkurius, Venus, Bulan) dan untuk tanggal yang jauh dari acuan. Untuk derajat presisi, tetap butuh efemeris harian.</p>
          <h3>Kesimpulan</h3>
          <p>Sebagai catatan posisi planet & harga harian, alat ini akurat dan rapi. Sebagai <b>prediksi arah</b> XAUUSD, astrologi tidak memiliki dasar dan pada periode ini berlawanan dengan pergerakan harga sebenarnya. Untuk keputusan nyata, andalkan kebijakan Fed & suku bunga, inflasi, imbal hasil obligasi, kekuatan dolar (DXY), dan geopolitik. Bukan nasihat keuangan.</p>
        </div>
      </details>

      <footer class="astro-calc-footer">Dibuat 2 Juli 2026 · Data tersimpan lokal di browser (localStorage). Ekspor CSV untuk cadangan.</footer>
    </div>
    <div class="toast" id="toast"></div>
  </div>

  <Footer />
</Layout>

<style is:global>
  /* Base wrapper to containerize original styles */
  .astro-dashboard-page {
    --midnight: #030712; 
    --midnight2: #090e1a; 
    --panel: #111827; 
    --panel2: #1f2937;
    --ivory: #f9fafb; 
    --muted: #9ca3af; 
    --line: rgba(255, 255, 255, 0.08);
    --gold: #3b82f6; 
    --gold-soft: #60a5fa; 
    --teal: #5FB0B7; 
    --crim: #C7566A; 
    --green: #7FBF8A;

    background:
      radial-gradient(1200px 600px at 80% -10%, rgba(59, 130, 246, 0.1), transparent 60%),
      radial-gradient(900px 500px at 10% 0%, rgba(95, 176, 183, 0.08), transparent 55%),
      var(--midnight);
    color: var(--ivory);
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    line-height: 1.5; 
    padding: 24px; 
    min-height: 100vh;
    position: relative;
    z-index: 10;
  }

  .astro-dashboard-page * {
    box-sizing: border-box;
  }

  .astro-dashboard-page .wrap {
    max-width: 1080px;
    margin: 0 auto;
  }

  .astro-dashboard-page h1,
  .astro-dashboard-page h2,
  .astro-dashboard-page h3 {
    font-family: "Iowan Old Style", Palatino, "Palatino Linotype", Georgia, serif;
    font-weight: 600;
    margin: 0;
  }

  .astro-dashboard-page .num {
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
  }

  /* Header */
  .astro-dashboard-page header {
    margin-bottom: 18px;
  }
  
  .astro-dashboard-page .eyebrow {
    letter-spacing: .28em;
    text-transform: uppercase;
    font-size: 11px;
    color: var(--gold);
    margin-bottom: 6px;
  }
  
  .astro-dashboard-page h1 {
    font-size: 30px;
    line-height: 1.1;
  }
  
  .astro-dashboard-page h1 .accent {
    color: var(--gold);
  }
  
  .astro-dashboard-page .sub {
    color: var(--muted);
    font-size: 14px;
    margin-top: 6px;
    max-width: 70ch;
  }
  
  .astro-dashboard-page .disclaimer {
    margin-top: 14px;
    border: 1px solid var(--line);
    border-left: 3px solid var(--gold);
    background: rgba(59, 130, 246, 0.06);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 12.5px;
    color: #cfd2ec;
  }
  
  .astro-dashboard-page .disclaimer b {
    color: var(--gold-soft);
  }

  /* Sky band (signature) */
  .astro-dashboard-page .sky {
    margin: 22px 0;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: linear-gradient(180deg, var(--midnight2), var(--panel));
    overflow: hidden;
  }
  
  .astro-dashboard-page .sky-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 12px 16px 4px;
  }
  
  .astro-dashboard-page .sky-head .lbl {
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--muted);
  }
  
  .astro-dashboard-page .sky-head .dt {
    font-size: 13px;
    color: var(--gold-soft);
  }
  
  .astro-dashboard-page .band {
    position: relative;
    height: 92px;
    margin: 6px 10px 14px;
  }
  
  .astro-dashboard-page .band .zone {
    position: absolute;
    top: 34px;
    height: 26px;
    border-right: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: .04em;
  }
  
  .astro-dashboard-page .band .zone:nth-child(odd) {
    background: rgba(255, 255, 255, 0.02);
  }
  
  .astro-dashboard-page .band .glyph {
    position: absolute;
    top: 2px;
    transform: translateX(-50%);
    text-align: center;
    transition: left .5s cubic-bezier(.22,.61,.36,1);
  }
  
  .astro-dashboard-page .band .glyph .g {
    font-size: 20px;
    line-height: 1;
    color: var(--gold);
  }
  
  .astro-dashboard-page .band .glyph .g.slow {
    color: var(--teal);
  }
  
  .astro-dashboard-page .band .glyph .p {
    font-size: 8.5px;
    color: var(--muted);
    margin-top: 1px;
    white-space: nowrap;
  }

  /* Layout Grid */
  .astro-dashboard-page .grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 18px;
  }
  
  @media(max-width: 820px) {
    .astro-dashboard-page .grid {
      grid-template-columns: 1fr;
    }
  }
  
  .astro-dashboard-page .card {
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--panel);
    padding: 16px 18px;
  }
  
  .astro-dashboard-page .card h2 {
    font-size: 17px;
    margin-bottom: 4px;
  }
  
  .astro-dashboard-page .card .hint {
    color: var(--muted);
    font-size: 12px;
    margin-bottom: 12px;
  }

  .astro-dashboard-page label {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin: 10px 0 4px;
  }
  
  .astro-dashboard-page input[type=date],
  .astro-dashboard-page input[type=number],
  .astro-dashboard-page input[type=text],
  .astro-dashboard-page textarea,
  .astro-dashboard-page select {
    width: 100%;
    background: var(--midnight2);
    border: 1px solid var(--line);
    color: var(--ivory);
    border-radius: 9px;
    padding: 9px 11px;
    font-size: 14px;
    font-family: inherit;
  }
  
  .astro-dashboard-page input:focus,
  .astro-dashboard-page textarea:focus,
  .astro-dashboard-page select:focus {
    outline: 2px solid var(--gold);
    outline-offset: 0;
    border-color: var(--gold);
  }
  
  .astro-dashboard-page textarea {
    resize: vertical;
    min-height: 52px;
  }
  
  .astro-dashboard-page .row2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .astro-dashboard-page .pos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
    margin-top: 8px;
  }
  
  .astro-dashboard-page .pos {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--midnight2);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 7px 9px;
  }
  
  .astro-dashboard-page .pos .pg {
    font-size: 16px;
    color: var(--gold);
    width: 18px;
    text-align: center;
  }
  
  .astro-dashboard-page .pos .pg.slow {
    color: var(--teal);
  }
  
  .astro-dashboard-page .pos .pn {
    font-size: 10.5px;
    color: var(--muted);
  }
  
  .astro-dashboard-page .pos .pv {
    font-size: 12.5px;
    font-weight: 600;
  }

  /* Buttons */
  .astro-dashboard-page .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    border-radius: 10px;
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    padding: 11px 16px;
    cursor: pointer;
    transition: transform .12s, filter .12s;
  }
  
  .astro-dashboard-page .btn:hover {
    filter: brightness(1.08);
  } 
  
  .astro-dashboard-page .btn:active {
    transform: translateY(1px);
  }
  
  .astro-dashboard-page .btn-gold {
    background: linear-gradient(180deg, var(--gold-soft), var(--gold));
    color: #2a2200;
  }
  
  .astro-dashboard-page .btn-ghost {
    background: transparent;
    border: 1px solid var(--line);
    color: var(--ivory);
  }
  
  .astro-dashboard-page .btn-sm {
    font-size: 12px;
    padding: 7px 11px;
  }
  
  .astro-dashboard-page .toolbar {
    display: flex;
    gap: 9px;
    flex-wrap: wrap;
    margin-top: 14px;
  }

  /* Chart */
  .astro-dashboard-page .chart-card {
    margin-top: 18px;
  }
  
  .astro-dashboard-page .chart-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
  }
  
  .astro-dashboard-page .last {
    font-size: 13px;
    color: var(--muted);
  }
  
  .astro-dashboard-page .last b {
    color: var(--gold-soft);
    font-size: 15px;
  }
  
  .astro-dashboard-page canvas {
    width: 100%;
    height: 300px;
    display: block;
    margin-top: 8px;
  }

  /* Table */
  .astro-dashboard-page .table-card {
    margin-top: 18px;
    overflow-x: auto;
  }
  
  .astro-dashboard-page table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
    min-width: 760px;
  }
  
  .astro-dashboard-page th,
  .astro-dashboard-page td {
    text-align: left;
    padding: 8px 9px;
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
  }
  
  .astro-dashboard-page th {
    color: var(--gold-soft);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: .04em;
    text-transform: uppercase;
    position: sticky;
    top: 0;
    background: var(--panel);
  }
  
  .astro-dashboard-page td.note {
    white-space: normal;
    min-width: 200px;
    color: #cfd2ec;
  }
  
  .astro-dashboard-page tr:hover td {
    background: rgba(255, 255, 255, 0.03);
  }
  
  .astro-dashboard-page .tag {
    font-size: 10px;
    padding: 2px 7px;
    border-radius: 20px;
    border: 1px solid;
  }
  
  .astro-dashboard-page .tag.aktual {
    color: var(--green);
    border-color: rgba(127,191,138,.5);
    background: rgba(127,191,138,.08);
  }
  
  .astro-dashboard-page .tag.sheet {
    color: var(--gold-soft);
    border-color: rgba(59,130,246,.4);
    background: rgba(59, 130, 246, 0.07);
  }
  
  .astro-dashboard-page .tag.model {
    color: var(--teal);
    border-color: rgba(95,176,183,.4);
    background: rgba(95,176,183,.07);
  }
  
  .astro-dashboard-page .del {
    background: none;
    border: none;
    color: var(--crim);
    cursor: pointer;
    font-size: 14px;
    padding: 2px 6px;
    border-radius: 6px;
  }
  
  .astro-dashboard-page .del:hover {
    background: rgba(199,86,106,.15);
  }

  /* Research */
  .astro-dashboard-page details.research {
    margin-top: 18px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--panel);
    overflow: hidden;
  }
  
  .astro-dashboard-page details.research summary {
    cursor: pointer;
    padding: 15px 18px;
    font-family: "Iowan Old Style", Palatino, Georgia, serif;
    font-size: 17px;
    color: var(--gold-soft);
    list-style: none;
  }
  
  .astro-dashboard-page details.research summary::-webkit-details-marker {
    display: none;
  }
  
  .astro-dashboard-page details.research summary::before {
    content: "▸ ";
    color: var(--gold);
  }
  
  .astro-dashboard-page details.research[open] summary::before {
    content: "▾ ";
  }
  
  .astro-dashboard-page .research .body {
    padding: 2px 20px 18px;
    font-size: 13.5px;
    color: #d7dbf2;
  }
  
  .astro-dashboard-page .research .body h3 {
    font-size: 14px;
    color: var(--gold-soft);
    margin: 16px 0 4px;
  }
  
  .astro-dashboard-page .research .body p {
    margin: 6px 0;
  }
  
  .astro-dashboard-page .research .body ul {
    margin: 6px 0;
    padding-left: 18px;
  } 
  
  .astro-dashboard-page .research .body li {
    margin: 3px 0;
  }
  
  .astro-dashboard-page .kpi {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin: 10px 0;
  }
  
  .astro-dashboard-page .kpi div {
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 9px 13px;
    background: var(--midnight2);
  }
  
  .astro-dashboard-page .kpi .k {
    font-size: 11px;
    color: var(--muted);
  } 
  
  .astro-dashboard-page .kpi .v {
    font-size: 18px;
    font-weight: 700;
  }
  
  .astro-dashboard-page .kpi .down {
    color: var(--crim);
  } 
  
  .astro-dashboard-page .kpi .up {
    color: var(--green);
  }

  .astro-dashboard-page footer.astro-calc-footer {
    margin-top: 22px;
    color: var(--muted);
    font-size: 11.5px;
    text-align: center;
    border: none;
    padding: 0;
  }
  
  .astro-dashboard-page .toast {
    position: fixed;
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--gold);
    color: #2a2200;
    font-weight: 600;
    font-size: 13px;
    padding: 10px 18px;
    border-radius: 10px;
    opacity: 0;
    pointer-events: none;
    transition: .25s;
    z-index: 1000;
  }
  
  .astro-dashboard-page .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script is:inline>
  /* ---------- No-retrograde mean-motion model (tropical) ---------- */
  const SIGNS=["Aries","Taurus","Gemini","Cancer","Leo","Virgo","Libra","Scorpio","Sagittarius","Capricorn","Aquarius","Pisces"];
  const EPOCH=Date.UTC(2026,6,2); // 2 Jul 2026
  
  // lon = absolute ecliptic longitude at epoch; rate = deg/day (forward only)
  const BODIES=[
    {key:"Sun",    g:"☉", lon:100.5, rate:0.98565, slow:false},
    {key:"Moon",   g:"☽", lon:317.2, rate:13.1764, slow:false},
    {key:"Venus",  g:"♀", lon:116.0, rate:1.10,    slow:false},
    {key:"Mars",   g:"♂", lon:63.0,  rate:0.524,   slow:false},
    {key:"Mercury",g:"☿", lon:110.0, rate:1.20,    slow:false},
    {key:"Jupiter",g:"♃", lon:121.0, rate:0.0831,  slow:true},
    {key:"Saturn", g:"♄", lon:14.0,  rate:0.0339,  slow:true},
  ];

  function lonOf(body,dateStr){
    const d=(Date.parse(dateStr+"T00:00:00Z")-EPOCH)/86400000;
    return ((body.lon+body.rate*d)%360+360)%360;
  }

  function fmtPos(lon){
    const s=Math.floor(lon/30)%12, deg=lon%30;
    return Math.floor(deg)+"° "+SIGNS[s];
  }

  function positionsFor(dateStr){
    const o={};
    BODIES.forEach(b=>o[b.key]=fmtPos(lonOf(b,dateStr)));
    return o;
  }

  /* ---------- Storage ---------- */
  const KEY="astro_xauusd_v1";
  let mem=null;

  function load(){
    try{const r=localStorage.getItem(KEY); if(r) return JSON.parse(r);}catch(e){}
    return mem;
  }

  function save(data){
    try{localStorage.setItem(KEY,JSON.stringify(data));}catch(e){mem=data;}
  }

  const SEED=[
    {date:"2026-01-29",close:5602,src:"aktual",note:"Rekor tertinggi sepanjang masa (ATH)."},
    {date:"2026-03-19",close:4600,src:"sheet",note:"Range lebar; High 4.867 / Low 4.502 (klaim sheet, estimasi tengah)."},
    {date:"2026-03-24",close:4474,src:"sheet",note:"Close 4.474 (klaim sheet). Sun masuk Aries."},
    {date:"2026-03-31",close:4667,src:"sheet",note:"Close 4.667 (klaim sheet)."},
    {date:"2026-04-19",close:null,src:"model",note:"Sun masuk Taurus; Mars sejajar Saturn di Aries."},
    {date:"2026-06-21",close:null,src:"model",note:"Sun masuk Cancer (solstice)."},
    {date:"2026-06-28",close:3960,src:"aktual",note:"Terendah ~8 bulan."},
    {date:"2026-06-30",close:null,src:"model",note:"Jupiter masuk Leo — perpindahan besar."},
    {date:"2026-07-01",close:4026,src:"aktual",note:"Rebound dari ~3.967."},
    {date:"2026-07-02",close:4066,src:"aktual",note:"Naik ~0,92% dari hari sebelumnya."},
  ];

  function seedRows(){return SEED.map(s=>({...s,pos:positionsFor(s.date)}));}

  let rows = load() || seedRows();

  /* ---------- Rendering ---------- */
  const $=id=>document.getElementById(id);
  const idr=n=> n==null?"—":Number(n).toLocaleString("id-ID",{maximumFractionDigits:2});

  function sortRows(){rows.sort((a,b)=>a.date.localeCompare(b.date));}

  function renderBand(dateStr){
    const band=$("band"); if(!band) return;
    band.innerHTML="";
    const W=band.clientWidth||band.offsetWidth||900;
    for(let i=0;i<12;i++){
      const z=document.createElement("div"); z.className="zone";
      z.style.left=(i/12*100)+"%"; z.style.width=(100/12)+"%";
      z.textContent=SIGNS[i].slice(0,3); band.appendChild(z);
    }
    // stagger vertical to reduce overlap
    const tops=[0,26,0,26,0,4,4];
    BODIES.forEach((b,idx)=>{
      const lon=lonOf(b,dateStr);
      const el=document.createElement("div"); el.className="glyph";
      el.style.left=(lon/360*100)+"%";
      el.style.top=(tops[idx]||0)+"px";
      el.innerHTML=`<div class="g ${b.slow?'slow':''}">${b.g}</div><div class="p">${fmtPos(lon)}</div>`;
      band.appendChild(el);
    });
    
    const skyDate = $("skyDate");
    if(skyDate) {
      skyDate.textContent=new Date(dateStr+"T00:00:00").toLocaleDateString("id-ID",{day:"numeric",month:"long",year:"numeric"});
    }
  }

  function renderPosGrid(dateStr){
    const pos=positionsFor(dateStr); const g=$("posGrid"); if(!g) return;
    g.innerHTML="";
    BODIES.forEach(b=>{
      const d=document.createElement("div"); d.className="pos";
      d.innerHTML=`<span class="pg ${b.slow?'slow':''}">${b.g}</span><div><div class="pn">${b.key}</div><div class="pv">${pos[b.key]}</div></div>`;
      g.appendChild(d);
    });
  }

  function renderTable(){
    const tb=$("tbody"); if(!tb) return;
    tb.innerHTML="";
    rows.forEach((r,i)=>{
      const tr=document.createElement("tr");
      const p=r.pos||positionsFor(r.date);
      tr.innerHTML=`<td class="num">${r.date}</td>
        <td>${p.Sun}</td><td>${p.Moon}</td><td>${p.Venus}</td><td>${p.Mars}</td>
        <td>${p.Mercury}</td><td>${p.Jupiter}</td><td>${p.Saturn}</td>
        <td class="num">${r.close==null?"—":idr(r.close)}</td>
        <td><span class="tag ${r.src}">${r.src}</span></td>
        <td class="note">${r.note||""}</td>
        <td><button class="del" data-i="${i}" title="Hapus">✕</button></td>`;
      tb.appendChild(tr);
    });
    tb.querySelectorAll(".del").forEach(b=>b.onclick=()=>{
      const index = parseInt(b.getAttribute("data-i"), 10);
      rows.splice(index,1);
      commit();
    });
  }

  /* ---------- Chart (custom canvas, no dependency) ---------- */
  function drawChart(){
    const cv=$("chart"); if(!cv) return;
    const ctx=cv.getContext("2d"); if(!ctx) return;
    const dpr=window.devicePixelRatio||1;
    const w=cv.clientWidth, h=300; cv.width=w*dpr; cv.height=h*dpr; ctx.scale(dpr,dpr);
    ctx.clearRect(0,0,w,h);
    const pts=rows.filter(r=>r.close!=null).map(r=>({t:Date.parse(r.date+"T00:00:00Z"),v:+r.close})).sort((a,b)=>a.t-b.t);
    const padL=54,padR=14,padT=14,padB=28;
    const cw=w-padL-padR, ch=h-padT-padB;
    if(pts.length===0){ctx.fillStyle="#9AA0C8";ctx.font="13px system-ui";ctx.fillText("Belum ada harga. Tambahkan lewat panel kiri.",padL,h/2);return;}
    const vmin=Math.min(...pts.map(p=>p.v)),vmax=Math.max(...pts.map(p=>p.v));
    const pad=(vmax-vmin)*0.12||100; const lo=vmin-pad,hi=vmax+pad;
    const tmin=pts[0].t,tmax=pts[pts.length-1].t||tmin+1;
    const X=t=>padL+(tmax===tmin?0.5:(t-tmin)/(tmax-tmin))*cw;
    const Y=v=>padT+(1-(v-lo)/(hi-lo))*ch;
    // gridlines + y labels
    ctx.strokeStyle="#33396E";ctx.fillStyle="#9AA0C8";ctx.font="11px system-ui";ctx.lineWidth=1;
    for(let i=0;i<=4;i++){
      const v=lo+(hi-lo)*i/4, y=Y(v);
      ctx.beginPath();ctx.moveTo(padL,y);ctx.lineTo(w-padR,y);ctx.stroke();
      ctx.fillText(Math.round(v).toLocaleString("id-ID"),6,y+4);
    }
    // area
    const grad=ctx.createLinearGradient(0,padT,0,padT+ch);
    grad.addColorStop(0,"rgba(59, 130, 246, 0.35)");grad.addColorStop(1,"rgba(59, 130, 246, 0)"); // Swapped gold gradient for electric blue
    ctx.beginPath();ctx.moveTo(X(pts[0].t),Y(pts[0].v));
    pts.forEach(p=>ctx.lineTo(X(p.t),Y(p.v)));
    ctx.lineTo(X(pts[pts.length-1].t),padT+ch);ctx.lineTo(X(pts[0].t),padT+ch);ctx.closePath();
    ctx.fillStyle=grad;ctx.fill();
    // line
    ctx.beginPath();ctx.moveTo(X(pts[0].t),Y(pts[0].v));
    pts.forEach(p=>ctx.lineTo(X(p.t),Y(p.v)));
    ctx.strokeStyle="#60a5fa";ctx.lineWidth=2.2;ctx.stroke(); // Swapped gold line for light blue
    // points + date labels (first/last)
    ctx.fillStyle="#60a5fa";
    pts.forEach(p=>{ctx.beginPath();ctx.arc(X(p.t),Y(p.v),3,0,7);ctx.fill();});
    ctx.fillStyle="#9AA0C8";ctx.font="10px system-ui";
    const f=new Date(pts[0].t),l=new Date(pts[pts.length-1].t);
    ctx.fillText(f.toLocaleDateString("id-ID",{day:"2-digit",month:"short"}),padL,h-8);
    ctx.textAlign="right";ctx.fillText(l.toLocaleDateString("id-ID",{day:"2-digit",month:"short"}),w-padR,h-8);ctx.textAlign="left";
    // last box
    const last=pts[pts.length-1], prev=pts[pts.length-2];
    let chg="";
    if(prev){const d=last.v-prev.v,pct=d/prev.v*100;const up=d>=0;
      chg=` · <span style="color:${up?'#7FBF8A':'#C7566A'}">${up?'▲':'▼'} ${idr(Math.abs(d))} (${pct.toFixed(2)}%)</span>`;}
    const lastBox = $("lastBox");
    if(lastBox) {
      lastBox.innerHTML=`Terakhir: <b>${idr(last.v)}</b> USD/oz${chg}`;
    }
  }

  /* ---------- KPI ---------- */
  function renderKPI(){
    const priced=rows.filter(r=>r.close!=null).sort((a,b)=>a.date.localeCompare(b.date));
    const box=$("kpi"); if(!box) return;
    box.innerHTML="";
    if(!priced.length)return;
    const ath=Math.max(...priced.map(r=>+r.close));
    const last=priced[priced.length-1];
    const first=priced[0];
    const chg=((last.close-first.close)/first.close*100);
    const items=[
      ["Terakhir (USD/oz)",idr(last.close),""],
      ["Tertinggi tercatat",idr(ath),""],
      ["Perubahan periode",chg.toFixed(1)+"%",chg>=0?"up":"down"],
    ];
    items.forEach(([k,v,c])=>{const d=document.createElement("div");d.innerHTML=`<div class="k">${k}</div><div class="v ${c}">${v}</div>`;box.appendChild(d);});
  }

  /* ---------- Commit / events ---------- */
  function commit(){sortRows();save(rows);renderTable();drawChart();renderKPI();}
  function toast(m){const t=$("toast"); if(!t) return; t.textContent=m;t.classList.add("show");setTimeout(()=>t.classList.remove("show"),1800);}

  function refreshInputPreview(){
    const dInput = $("dInput"); if(!dInput) return;
    const d=dInput.value; if(!d) return;
    renderBand(d);renderPosGrid(d);
  }

  /* ---------- Init ---------- */
  function init(){
    rows = load() || seedRows();
    const dInput = $("dInput");
    if (dInput) {
      dInput.value=new Date().toISOString().slice(0,10);
    }
    
    refreshInputPreview();
    commit();

    const todayBtn = $("todayBtn");
    if(todayBtn) {
      todayBtn.onclick=()=>{
        if(dInput) {
          dInput.value=new Date().toISOString().slice(0,10);
          refreshInputPreview();
        }
      };
    }

    const saveBtn = $("saveBtn");
    if(saveBtn) {
      saveBtn.onclick=()=>{
        if(!dInput) return;
        const date=dInput.value; if(!date){toast("Pilih tanggal dulu");return;}
        const pInput = $("pInput");
        const sInput = $("sInput");
        const nInput = $("nInput");
        const pv=pInput?pInput.value:"";
        const close=pv===""?null:parseFloat(pv);
        const src=close==null?"model":(sInput?sInput.value:"aktual");
        const note=nInput?nInput.value.trim():"";
        const pos=positionsFor(date);
        const ex=rows.findIndex(r=>r.date===date);
        const rec={date,close,src,note:note||(ex>=0?rows[ex].note:""),pos};
        if(ex>=0) rows[ex]=rec; else rows.push(rec);
        commit(); 
        if(pInput) pInput.value="";
        if(nInput) nInput.value="";
        toast(ex>=0?"Data "+date+" diperbarui":"Data "+date+" disimpan");
      };
    }

    const csvBtn = $("csvBtn");
    if(csvBtn) {
      csvBtn.onclick=()=>{
        const head=["Tanggal","Sun","Moon","Venus","Mars","Mercury","Jupiter","Saturn","Harga","Sumber","Catatan"];
        const lines=[head.join(",")];
        rows.forEach(r=>{const p=r.pos||positionsFor(r.date);
          lines.push([r.date,p.Sun,p.Moon,p.Venus,p.Mars,p.Mercury,p.Jupiter,p.Saturn,r.close??"",r.src,'"'+(r.note||"").replace(/"/g,'""')+'"'].join(","));});
        const blob=new Blob([lines.join("\n")],{type:"text/csv"});
        const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="astro_xauusd.csv";a.click();
        toast("CSV diekspor");
      };
    }

    const resetBtn = $("resetBtn");
    if(resetBtn) {
      resetBtn.onclick=()=>{if(confirm("Kembalikan ke data awal? Perubahan Anda akan hilang.")){rows=seedRows();commit();toast("Direset ke data awal");}};
    }

    window.addEventListener("resize",()=>{drawChart();refreshInputPreview();});
  }

  // Handle load & Astro swapping
  init();
  document.addEventListener('astro:after-swap', () => {
    init();
  });
</script>
