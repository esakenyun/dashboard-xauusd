const FUTURE_BODIES = ['sun','moon','venus','mars','mercury','jupiter','saturn'];
const FUTURE_LABEL = {sun:'Sun',moon:'Moon',venus:'Venus',mars:'Mars',mercury:'Mercury',jupiter:'Jupiter',saturn:'Saturn'};

function findFutureRow(dateStr){
  return FUTURE_EPHEM.find(r => r[0] === dateStr);
}

function renderPrediction(){
  const dateInEl = document.getElementById('predDateIn');
  if(!dateInEl) return;
  const dateStr = dateInEl.value;
  const row = findFutureRow(dateStr);
  const div = document.getElementById('predResult');
  if(!row){
    div.innerHTML = '<div style="color:var(--mars);font-family:var(--mono);font-size:12px">Tanggal di luar jangkauan data (17 Jul 2026 - 31 Des 2029).</div>';
    return;
  }
  let idx = 1;
  const positions = {};
  FUTURE_BODIES.forEach(b => {
    positions[b] = {deg: row[idx], sign: ZODIAC12[row[idx+1]]};
    idx += 2;
  });

  let sumWN = 0, sumN = 0;
  const parts = [];
  FUTURE_BODIES.forEach(b => {
    const cell = WINRATE.signs[b] ? WINRATE.signs[b][positions[b].sign] : null;
    if(cell){
      const [wr,n] = cell;
      sumWN += wr*n; sumN += n;
      parts.push(FUTURE_LABEL[b]+' di '+positions[b].sign+' ('+wr.toFixed(0)+'%, n='+n+')');
    }
  });
  const composite = sumN>0 ? sumWN/sumN : 50;

  let posHtml = '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px">';
  FUTURE_BODIES.forEach(b => {
    posHtml += `<div style="background:#0f1220;border:1px solid var(--line);border-radius:6px;padding:8px 10px">
      <div style="font-family:var(--mono);font-size:10px;color:var(--ink-dim)">${FUTURE_LABEL[b].toUpperCase()}</div>
      <div style="font-family:var(--display);font-size:15px;color:var(--ink)">${positions[b].deg}° ${positions[b].sign}</div>
    </div>`;
  });
  posHtml += '</div>';

  const bull = composite, bear = 100-composite;
  const confLabel = sumN>=3000?'Tinggi':sumN>=1000?'Sedang':'Rendah';

  div.innerHTML = posHtml + `
    <div style="background:var(--bg2);border:1px solid var(--gold);border-radius:10px;padding:16px 18px">
      <div style="display:flex;gap:20px;margin-bottom:10px">
        <div><div style="font-family:var(--mono);font-size:10px;color:var(--ink-dim)">BULL PROBABILITY</div><div style="font-family:var(--display);font-size:28px;color:var(--ok);font-weight:700">${bull.toFixed(1)}%</div></div>
        <div><div style="font-family:var(--mono);font-size:10px;color:var(--ink-dim)">BEAR PROBABILITY</div><div style="font-family:var(--display);font-size:28px;color:var(--mars);font-weight:700">${bear.toFixed(1)}%</div></div>
        <div><div style="font-family:var(--mono);font-size:10px;color:var(--ink-dim)">CONFIDENCE</div><div style="font-family:var(--display);font-size:28px;color:var(--gold);font-weight:700">${confLabel}</div><div style="font-family:var(--mono);font-size:9px;color:var(--ink-dim)">total n=${sumN}</div></div>
      </div>
