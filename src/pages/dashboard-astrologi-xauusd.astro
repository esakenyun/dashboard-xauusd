              <div class="field"><label>JAM SUNSET NY (default 20,5 = 20:30)</label><input id="sunsetIn" type="number" value="20.5" min="12" max="23" step="0.5"></div>
              <div id="hourResult" style="margin-top:14px"></div>
            </div>
            <div>
              <h3>Relevansi ke Komoditas</h3>
              <table style="font-size:13px">
                <thead><tr><th>Jam Planet</th><th>Efek Intraday</th></tr></thead>
                <tbody>
                  <tr><td>☉ Sun</td><td>Breakout/momentum Gold paling murni (ruler langsung)</td></tr>
