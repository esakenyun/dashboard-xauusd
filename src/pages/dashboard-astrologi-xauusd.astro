let currentFilter = 'all';
let currentSearch = '';

function signalMatchesFilter(sig, filter){
  if(filter==='all') return true;
  if(filter==='Bullish') return sig[2] > 55;
  if(filter==='Bearish') return sig[2] < 45;
  return sig[1] === filter;
}

function renderMasterTable(){
  const tbody = document.getElementById('masterSignalBody');
  if(!tbody) return;
  tbody.innerHTML = '';
  const q = currentSearch.toLowerCase();
  let filtered = MASTER_SIGNALS.filter(sig => signalMatchesFilter(sig, currentFilter) && sig[0].toLowerCase().includes(q));
  filtered.sort((a,b) => Math.abs(b[3]) - Math.abs(a[3]));
  filtered.forEach(sig => {
    const label = sig[0], cat = sig[1], wr = sig[2], score = sig[3], n = sig[4];
    const dirClass = wr>50 ? 'up' : wr<50 ? 'down' : 'flat';
    const scoreColor = score>0 ? 'var(--ok)' : score<0 ? 'var(--mars)' : 'var(--ink-dim)';
    const tr = document.createElement('tr');
    tr.innerHTML = '<td>'+label+'</td><td style="font-family:var(--mono);font-size:11px;color:var(--ink-dim)">'+cat+'</td><td class="'+dirClass+'">'+wr+'%</td><td style="color:'+scoreColor+';font-weight:700">'+(score>0?'+':'')+score+'</td><td>'+n+'</td>';
    tbody.appendChild(tr);
  });
  if(filtered.length===0){
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--ink-dim);padding:20px">Gak ada signal yang cocok.</td></tr>';
  }
}

function bindMasterSignalHandlers(){
  const searchEl = document.getElementById('signalSearch');
  if(searchEl){
    searchEl.oninput = function(e){
      currentSearch = e.target.value;
      renderMasterTable();
    };
  }
  document.querySelectorAll('#filterButtons .filter-btn').forEach(function(btn){
    btn.onclick = function(){
      document.querySelectorAll('#filterButtons .filter-btn').forEach(function(b){b.classList.remove('active');});
      btn.classList.add('active');
      currentFilter = btn.dataset.cat;
      renderMasterTable();
    };
  });
}

function renderMasterChart(){
  const svg = document.getElementById('masterChart');
  if(!svg) return;
  const top15 = MASTER_SIGNALS.slice().sort(function(a,b){return Math.abs(b[3]) - Math.abs(a[3]);}).slice(0,15);
  const barHeight = 22, gap = 10, leftPad = 300, barMax = 130, topPad = 10, svgW = 800, scoreColX = 730;
  const maxAbsScore = Math.max.apply(null, top15.map(function(s){return Math.abs(s[3]);}));
  let bgHtml = '', fgHtml = '';
  top15.forEach(function(sig, i){
    const label = sig[0], score = sig[3];
    const y = topPad + i*(barHeight+gap);
    const barW = Math.max(2, Math.abs(score)/maxAbsScore * barMax);
    const isPositive = score >= 0;
    const barX = isPositive ? leftPad : leftPad - barW;
    const color = isPositive ? '#7fa88a' : '#b5533c';
    const shortLabel = label.length > 26 ? label.slice(0,24)+'..' : label;
    if(i%2===0){
      bgHtml += '<rect x="0" y="'+(y-3)+'" width="'+svgW+'" height="'+(barHeight+6)+'" fill="#ffffff" opacity="0.02"/>';
    }
    bgHtml += '<rect x="'+barX+'" y="'+y+'" width="'+barW+'" height="'+barHeight+'" fill="'+color+'" rx="2"/>';
    fgHtml += '<text x="'+(leftPad-10)+'" y="'+(y+barHeight/2+4)+'" text-anchor="end" font-family="JetBrains Mono, monospace" font-size="10.5" fill="#e8e6df">'+shortLabel+'</text>';
    fgHtml += '<text x="'+scoreColX+'" y="'+(y+barHeight/2+4)+'" text-anchor="start" font-family="JetBrains Mono, monospace" font-size="11" font-weight="700" fill="'+color+'">'+(score>0?'+':'')+score+'</text>';
  });
  const chartBottom = topPad + 15*(barHeight+gap);
  const axisHtml = '<line x1="'+leftPad+'" y1="0" x2="'+leftPad+'" y2="'+chartBottom+'" stroke="#3a4258" stroke-width="1"/>' +
    '<line x1="'+(scoreColX-15)+'" y1="0" x2="'+(scoreColX-15)+'" y2="'+chartBottom+'" stroke="#262c40" stroke-width="1"/>';
  svg.innerHTML = axisHtml + bgHtml + fgHtml;
  svg.setAttribute('viewBox', '0 0 '+svgW+' '+(chartBottom + 10));
}

function init(){
  initTabs();

  bindMasterSignalHandlers();
  renderMasterTable();
  renderMasterChart();

  const priceEl = document.getElementById('priceIn'), degEl = document.getElementById('degIn');
  if(priceEl && degEl){
    priceEl.oninput = renderSQ9;
    degEl.oninput = renderSQ9;
    renderSQ9();
  }

  ['dayIn','hourIn','sunriseIn','sunsetIn'].forEach(id => {
    const el = document.getElementById(id);
    if(el){ el.oninput = renderChaldean; el.onchange = renderChaldean; }
  });
  renderChaldean();

  bindDatabaseHandlers();
  bindY10Handlers();

  buildHeatmap();
  buildPlanetInputs();
  buildAspectInputs();
  buildRanking();
  const planetSignInputsEl = document.getElementById('planetSignInputs'), aspectInputsEl = document.getElementById('aspectInputs');
  if(planetSignInputsEl) planetSignInputsEl.onchange = computeComposite;
  if(aspectInputsEl) aspectInputsEl.onchange = computeComposite;
  computeComposite();

  const predDateInEl = document.getElementById('predDateIn');
  if(predDateInEl) predDateInEl.oninput = renderPrediction;
  renderPrediction();

  const today = new Date().toISOString().split('T')[0];
  const dateEl = document.getElementById('f_date');
  if(dateEl) dateEl.value = today;
  loadCustom();
  renderTable();
  y10Filtered = Y10DATA;
  y10Page = 0;
  y10Render();
}

init();
document.addEventListener('astro:after-swap', init);
