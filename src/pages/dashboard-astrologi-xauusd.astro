const CUSTOM_KEY = 'xauusd_custom_rows';
let customRows = [];

function loadCustom(){
  try{
    const r = localStorage.getItem(CUSTOM_KEY);
    customRows = r ? JSON.parse(r) : [];
  }catch(e){ customRows = []; }
}
function saveCustom(){
  try{ localStorage.setItem(CUSTOM_KEY, JSON.stringify(customRows)); }catch(e){}
}

function autoSentiment(row){
  if(row.open==null || row.close==null) return row.note || '(belum ada harga)';
  const cp = ((row.close-row.open)/row.open*100);
  const rng = (row.high!=null && row.low!=null) ? (row.high-row.low) : null;
  let mood = cp>1.5?'Bullish Kuat':cp>0.3?'Bullish':cp<-1.5?'Bearish Kuat':cp<-0.3?'Bearish':'Konsolidasi';
  let s = mood + (rng!=null?`, range ${rng.toFixed(0)}pt`:'');
  if(row.note) s += ' — ' + row.note;
  return s;
}

function classForChange(cp){
  if(cp==null) return 'flat';
  return cp>0.05?'up':cp<-0.05?'down':'flat';
}

function renderStats(all){
  const withPrice = all.filter(r=>r.close!=null && r.open!=null);
  const ups = withPrice.filter(r=>r.close>r.open).length;
  const total = withPrice.length;
  const avgRange = withPrice.reduce((a,r)=>a+((r.high||r.close)-(r.low||r.open)),0)/(total||1);
  const el = document.getElementById('statRow');
  if(!el) return;
  el.innerHTML = `
    <div class="stat"><b>${total}</b>hari tercatat</div>
    <div class="stat"><b>${ups}/${total}</b>hari ditutup naik</div>
    <div class="stat"><b>${avgRange.toFixed(0)} pt</b>rata-rata range harian</div>
    <div class="stat"><b>${all.length ? all[all.length-1].date : '-'}</b>data terakhir</div>
  `;
}

function renderTable(){
  const searchEl = document.getElementById('searchBox');
  if(!searchEl) return;
  const merged = [...HISTORICAL.map(r=>({...r, src:'auto'})), ...customRows.map(r=>({...r, src:'you'}))];
  merged.sort((a,b)=>a.date.localeCompare(b.date));
  const q = searchEl.value.toLowerCase();
  const tbody = document.getElementById('tbody');
  tbody.innerHTML = '';
  merged.forEach(r=>{
    const sentiment = r.sentiment || autoSentiment(r);
    if(q && !(r.date.includes(q) || sentiment.toLowerCase().includes(q) || (r.ingress||'').toLowerCase().includes(q))) return;
    const cp = (r.open!=null && r.close!=null) ? ((r.close-r.open)/r.open*100) : null;
    const tr = document.createElement('tr');
    if(r.src==='you') tr.className='custom-row';
    tr.innerHTML = `
      <td>${r.date}</td>
      <td>${r.sun||''}</td><td>${r.moon||''}</td><td>${r.venus||''}</td><td>${r.mars||''}</td>
      <td>${r.mercury||''}</td><td>${r.jupiter||''}</td><td>${r.saturn||''}</td>
      <td>${r.open!=null?r.open:''}</td><td>${r.high!=null?r.high:''}</td><td>${r.low!=null?r.low:''}</td><td>${r.close!=null?r.close:''}</td>
      <td class="${classForChange(cp)}">${cp!=null?cp.toFixed(2)+'%':''}</td>
      <td>${sentiment}</td>
      <td><span class="tag-src ${r.src==='you'?'you':''}">${r.src==='you'?'KAMU':'AUTO'}</span></td>
    `;
    tbody.appendChild(tr);
  });
  renderStats(merged);
}

function bindDatabaseHandlers(){
  document.getElementById('searchBox').oninput = renderTable;

  document.getElementById('addBtn').onclick = ()=>{
    const row = {
      date: document.getElementById('f_date').value,
      sun: document.getElementById('f_sun').value,
      moon: document.getElementById('f_moon').value,
      venus: document.getElementById('f_venus').value,
      mars: document.getElementById('f_mars').value,
      mercury: document.getElementById('f_mercury').value,
      jupiter: document.getElementById('f_jupiter').value,
      saturn: document.getElementById('f_saturn').value,
      open: document.getElementById('f_open').value ? parseFloat(document.getElementById('f_open').value) : null,
      high: document.getElementById('f_high').value ? parseFloat(document.getElementById('f_high').value) : null,
      low: document.getElementById('f_low').value ? parseFloat(document.getElementById('f_low').value) : null,
      close: document.getElementById('f_close').value ? parseFloat(document.getElementById('f_close').value) : null,
      note: document.getElementById('f_note').value
    };
    if(!row.date){ document.getElementById('saveMsg').textContent = 'Isi tanggal dulu!'; return; }
    customRows = customRows.filter(r=>r.date!==row.date);
    customRows.push(row);
    saveCustom();
    renderTable();
    document.getElementById('saveMsg').textContent = 'Tersimpan ✓';
    setTimeout(()=>{const m=document.getElementById('saveMsg');if(m)m.textContent='';}, 2000);
    ['f_sun','f_moon','f_venus','f_mars','f_mercury','f_jupiter','f_saturn','f_open','f_high','f_low','f_close','f_note'].forEach(id=>document.getElementById(id).value='');
  };

  document.getElementById('clearCustomBtn').onclick = ()=>{
    if(!confirm('Hapus semua data custom yang kamu tambahkan?')) return;
    customRows = [];
    saveCustom();
    renderTable();
  };

  document.getElementById('exportBtn').onclick = ()=>{
    const merged = [...HISTORICAL.map(r=>({...r, src:'auto'})), ...customRows.map(r=>({...r, src:'you'}))];
    merged.sort((a,b)=>a.date.localeCompare(b.date));
    const headers = ['date','sun','moon','venus','mars','mercury','jupiter','saturn','open','high','low','close','sentiment','src'];
    const csv = [headers.join(',')].concat(merged.map(r=>headers.map(h=>{
      const v = h==='sentiment' ? (r.sentiment||autoSentiment(r)) : (r[h]??'');
      return `"${String(v).replace(/"/g,'""')}"`;
    }).join(','))).join('\n');
    const blob = new Blob([csv], {type:'text/csv'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'xauusd_astro_database.csv';
    a.click();
  };
}

const Y10_PAGE_SIZE = 50;
let y10Filtered = Y10DATA;
let y10Page = 0;

function y10Render(){
  const start = y10Page * Y10_PAGE_SIZE;
  const pageRows = y10Filtered.slice(start, start + Y10_PAGE_SIZE);
  const tbody = document.getElementById('y10tbody');
  if(!tbody) return;
  tbody.innerHTML = '';
  pageRows.forEach(r=>{
    const [date, sD,sS, mD,mS, vD,vS, maD,maS, meD,meS, jD,jS, saD,saS, open,high,low,close,cp] = r;
    const fmt = (d,s) => `${d}° ${ZODIAC12[s]}`;
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${date}</td>
      <td>${fmt(sD,sS)}</td><td>${fmt(mD,mS)}</td><td>${fmt(vD,vS)}</td><td>${fmt(maD,maS)}</td>
      <td>${fmt(meD,meS)}</td><td>${fmt(jD,jS)}</td><td>${fmt(saD,saS)}</td>
      <td>${open}</td><td>${high}</td><td>${low}</td><td>${close}</td>
      <td class="${cp>0.05?'up':cp<-0.05?'down':'flat'}">${cp}%</td>
    `;
    tbody.appendChild(tr);
  });
  const totalPages = Math.max(1, Math.ceil(y10Filtered.length / Y10_PAGE_SIZE));
  document.getElementById('y10pageinfo').textContent = `Halaman ${y10Page+1}/${totalPages} (${y10Filtered.length} baris)`;
}

function bindY10Handlers(){
  document.getElementById('y10search').oninput = (e)=>{
    const q = e.target.value.trim();
    y10Filtered = q ? Y10DATA.filter(r => r[0].includes(q)) : Y10DATA;
    y10Page = 0;
    y10Render();
  };
  document.getElementById('y10prev').onclick = ()=>{
    if(y10Page > 0){ y10Page--; y10Render(); }
  };
  document.getElementById('y10next').onclick = ()=>{
    const totalPages = Math.ceil(y10Filtered.length / Y10_PAGE_SIZE);
    if(y10Page < totalPages-1){ y10Page++; y10Render(); }
  };
}

