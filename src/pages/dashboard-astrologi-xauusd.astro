<script is:inline>
function initTabs(){
  document.querySelectorAll('.xauusd-terpadu-page .tabbtn').forEach(btn => {
    btn.onclick = () => {
      document.querySelectorAll('.xauusd-terpadu-page .tabbtn').forEach(b=>b.classList.remove('active'));
      document.querySelectorAll('.xauusd-terpadu-page .tabpanel').forEach(p=>p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-'+btn.dataset.tab).classList.add('active');
    };
  });
}

function computeLevels(price){
  const root = Math.sqrt(price);
  const degs = [0,45,90,135,180,225,270,315,360];
  return degs.map(d => ({deg:d, price: Math.pow(root + d/360, 2)}));
}

function computeLevelsSell(price){
  const root = Math.sqrt(price);
  const degs = [0,45,90,135,180,225,270,315,360];
  return degs.map(d => ({deg:d, price: Math.max(0, Math.pow(root - d/360, 2))}));
}

function renderSQ9(){
  const priceEl = document.getElementById('priceIn'), degEl = document.getElementById('degIn');
  if(!priceEl || !degEl) return;
  const price = parseFloat(priceEl.value) || 0;
  const customDeg = parseFloat(degEl.value) || 0;
  const levels = computeLevels(price);
  const levelsSell = computeLevelsSell(price);
  const grid = document.getElementById('resultsGrid');
  grid.innerHTML = '';
  levels.forEach(l=>{
    const div = document.createElement('div');
    div.innerHTML = `<div class="deg">${l.deg}°</div><div class="val">${l.price.toFixed(2)}</div>`;
    grid.appendChild(div);
  });
  const gridSell = document.getElementById('resultsGridSell');
  gridSell.innerHTML = '';
  levelsSell.forEach(l=>{
    const div = document.createElement('div');
    div.innerHTML = `<div class="deg">${l.deg}°</div><div class="val" style="color:var(--mars)">${l.price.toFixed(2)}</div>`;
    gridSell.appendChild(div);
  });
  const root = Math.sqrt(price);
  const customPriceBuy = Math.pow(root + customDeg/360, 2);
  const customPriceSell = Math.max(0, Math.pow(root - customDeg/360, 2));
  const div = document.createElement('div');
  div.style.gridColumn = '1 / -1';
  div.style.borderColor = 'var(--gold)';
  div.innerHTML = `<div class="deg">CUSTOM ${customDeg}° (BUY)</div><div class="val">${customPriceBuy.toFixed(2)}</div>`;
  grid.appendChild(div);
  const divSell = document.createElement('div');
  divSell.style.gridColumn = '1 / -1';
  divSell.style.borderColor = 'var(--mars)';
  divSell.innerHTML = `<div class="deg">CUSTOM ${customDeg}° (SELL)</div><div class="val" style="color:var(--mars)">${customPriceSell.toFixed(2)}</div>`;
  gridSell.appendChild(divSell);

  drawWheel(price);
}

function drawWheel(price){
  const svg = document.getElementById('sq9wheel');
  const cx=160, cy=160, maxR=140;
  const root = Math.sqrt(price || 1);
  let html = '';
  for(let r=20; r<=maxR; r+=20){
    html += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#262c40" stroke-width="1"/>`;
  }
  [0,45,90,135].forEach(a=>{
    const rad = a*Math.PI/180;
    const x1 = cx - maxR*Math.cos(rad), y1 = cy - maxR*Math.sin(rad);
    const x2 = cx + maxR*Math.cos(rad), y2 = cy + maxR*Math.sin(rad);
    html += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" class="cross" opacity="${a%90===0?0.9:0.35}"/>`;
  });
  const frac = root - Math.floor(root);
  const ang = frac*360*Math.PI/180;
  const markerR = maxR*0.6;
  const mx = cx + markerR*Math.cos(ang), my = cy - markerR*Math.sin(ang);
  html += `<circle cx="${mx}" cy="${my}" r="6" fill="#d4af6a"/>`;
  html += `<circle cx="${cx}" cy="${cy}" r="3" fill="#e8e6df"/>`;
  html += `<text x="${cx}" y="${cy+maxR+22}" text-anchor="middle" class="center-price">√${price||0} = ${root.toFixed(3)}</text>`;
  svg.innerHTML = html;
}

const CHALDEAN = ['Saturn','Jupiter','Mars','Sun','Venus','Mercury','Moon'];
const CHALDEAN_SYM = {Saturn:'♄',Jupiter:'♃',Mars:'♂',Sun:'☉',Venus:'♀',Mercury:'☿',Moon:'☽'};
const DAY_RULER_START = {0:'Sun',1:'Moon',2:'Mars',3:'Mercury',4:'Jupiter',5:'Venus',6:'Saturn'};
const DAY_NAMES = {0:'Minggu',1:'Senin',2:'Selasa',3:'Rabu',4:'Kamis',5:'Jumat',6:'Sabtu'};

function computeChaldeanHour(dayNum, hour, sunrise, sunset){
  const startPlanet = DAY_RULER_START[dayNum];
  const startIdx = CHALDEAN.indexOf(startPlanet);
  const dayLength = sunset - sunrise;
  const nightLength = 24 - dayLength;
  let hourIndexInDay;
  let isDay = true;
  if(hour >= sunrise && hour < sunset){
    hourIndexInDay = Math.floor((hour - sunrise) / (dayLength/12));
    isDay = true;
  } else {
    isDay = false;
    let hoursSinceSunset = hour >= sunset ? (hour - sunset) : (hour + 24 - sunset);
    hourIndexInDay = 12 + Math.floor(hoursSinceSunset / (nightLength/12));
  }
  const planet = CHALDEAN[(startIdx + hourIndexInDay) % 7];
  return {planet, slot: hourIndexInDay + 1, isDay};
}

